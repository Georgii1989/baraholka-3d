# Telegram Bot — create via @BotFather
TELEGRAM_BOT_TOKEN=
# Your personal chat id — get from @userinfobot
TELEGRAM_ADMIN_CHAT_ID=

# SQLite path (local dev)
DATABASE_PATH=./data/chat.db

# Public site URL (for Vercel webhook setup)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Keystatic (локально можно не задавать — CMS читает файлы из content/) ---
# На Vercel с GitHub: owner/repo
KEYSTATIC_GITHUB_REPO=

# После установки Keystatic GitHub App (см. docs/keystatic-setup.md)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
